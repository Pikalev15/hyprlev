{
    "position": "top",
    "height": 44,
    "spacing": 12,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "output": "eDP-1",
    "modules-left": [
        "custom/arch",
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "custom/weather",
        "clock"
    ],
    "modules-right": [
        "tray",
        "custom/updates",
        "pulseaudio",
        "network",
        "memory",
        "cpu",
        "battery",
        "custom/swaync",
        "custom/power"
    ],
    "hyprland/workspaces": {
        "format": "{id}",
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "persistent-workspaces": {
            "*": [
                1,
                2,
                3,
                4,
                5
            ]
        },
        "anim-color-1": "#89b4fa",
        "anim-color-2": "#cba6f7",
        "anim-duration": 3,
        "button-radius": 10,
        "button-pad-v": 0,
        "button-pad-h": 4,
        "button-minw": 35
    },
    "hyprland/window": {
        "format": "{}",
        "max-length": 60,
        "separate-outputs": true
    },
    "clock": {
        "format": "{:%H:%M  |  %A %d %B}",
        "timezone": "America/Monterrey",
        "locale": "es_MX.utf8",
        "interval": 1,
        "on-click": "flatpak run com.ml4w.calendar",
        "tooltip": true
    },
    "cpu": {
        "format": "ůįćõ {usage}%",
        "tooltip": true,
        "interval": 2
    },
    "memory": {
        "format": "ůįĺÜ {used:0.1f}G",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "interval": 5
    },
    "network": {
        "format-wifi": "ůįĖ© {signalStrength}%",
        "format-ethernet": "ůįąÄ {ipaddr}",
        "format-disconnected": "ůįĖ™ Sin red",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n{essid} ({signalStrength}%)\n‚ÜĎ {bandwidthUpBits}  ‚Üď {bandwidthDownBits}",
        "on-click": "nm-connection-editor",
        "interval": 5
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "ůįĚü mute",
        "format-icons": {
            "default": [
                "ůįēŅ",
                "ůįĖÄ",
                "ůįēĺ"
            ]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5
    },
    "wireplumber": {
        "format": "<span font='JetBrainsMono Nerd Font Mono 12'>ůįēĺ</span> {volume}%",
        "format-muted": "<span font='JetBrainsMono Nerd Font Mono 12'>ůįĚü</span> mute",
        "on-click": "pavucontrol",
        "scroll-step": 5
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": [
            "ůįĀļ",
            "ůįĀľ",
            "ůįĀĺ",
            "ůįāÄ",
            "ůįāā",
            "ůįĀĻ"
        ],
        "format-charging": "ůįāĄ {capacity}%",
        "format-plugged": "ůįö• {capacity}%",
        "states": {
            "warning": 30,
            "critical": 15
        }
    },
    "mpris": {
        "format": "{player_icon} {title}",
        "format-paused": "{player_icon}  {title}",
        "interval": 1,
        "max-length": 40
    },
    "tray": {
        "spacing": 8,
        "icon-size": 18
    },
    "custom/arch": {
        "format": "<span font='JetBrainsMono Nerd Font Mono 20' color='#cba6f7'>ůį£á</span>",
        "on-click": "$HOME/.local/bin/vsfetch",
        "tooltip": false,
        "arch-icon-glyph": "ůį£á",
        "arch-pad-left": 15,
        "arch-pad-right": 10
    },
    "custom/weather": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/weather.py",
        "return-type": "json",
        "interval": 3600,
        "tooltip": true,
        "on-click": "flatpak run io.github.amit9838.mousam"
    },
    "custom/updates": {
        "exec": "count=$(checkupdates 2>/dev/null | wc -l); [ \"$count\" -gt 0 ] && echo '{\"text\":\"ůįöį '\"$count\"'\",\"class\":\"pending\"}' || echo '{\"text\":\"ůįöį 0\",\"class\":\"updated\"}'",
        "return-type": "json",
        "interval": 60,
        "tooltip": false,
        "on-click": "kitty --class floating-terminal -e ~/.config/hypr/scripts/install-updates.sh"
    },
    "custom/swaync": {
        "format": "<span font='JetBrainsMono Nerd Font Mono 16'>{icon}</span>",
        "format-icons": {
            "none": "ůįāö",
            "notification": "ůįāú",
            "dnd-none": "ůįāõ",
            "dnd-notification": "ůįāõ"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
        "tooltip": false
    },
    "custom/power": {
        "format": "‚ŹĽ",
        "on-click": "wlogout -b 3 -c 20 -r 20 -L 400 -R 400 -T 200 -B 200 --protocol layer-shell",
        "tooltip": false
    }
}